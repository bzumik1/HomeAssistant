{
  "permissions": {
    "deny": [
      "Read(**/secrets.yaml)",
      "Grep(**/secrets.yaml)",
      "Edit(**/secrets.yaml)",
      "Write(**/secrets.yaml)",
      "Bash(*secrets.yaml*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-esphome.sh"
          }
        ]
      }
    ]
  }
}
